# BistroLink — Variables de entorno
# Copiar como .env y completar con valores reales.
# El .env está en .gitignore — NUNCA debe commitearse.
# ── Aplicación ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# ── Base de datos ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bistrolink:bistrolink_dev@localhost:5432/bistrolink_dev
# ── Autenticación ──────────────────────────────────────────────────────────
JWT_SECRET=                    # generate.plus/secret → 64 chars hex
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=bistrolink
KEYCLOAK_CLIENT_ID=bistrolink-backend
KEYCLOAK_CLIENT_SECRET=9oFlz0FVpYX3SeDwBt6uzjWQSGcGmytgs       # Keycloak Admin → Clients → bistrolink-backend → Credentials
# ── WhatsApp (Evolution API) ────────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8081
EVOLUTION_API_KEY=dev_key_local
# ── Pasarelas de pago ──────────────────────────────────────────────────────
PLEXO_CLIENT_NAME=
PLEXO_CLIENT_PASSWORD=
PLEXO_WEBHOOK_SECRET=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
HANDY_API_KEY=
HANDY_WEBHOOK_SECRET=
# ── Facturación electrónica ────────────────────────────────────────────────
SURTEC_API_KEY=
SURTEC_WEBHOOK_SECRET=
# ── Almacenamiento S3 (primario) ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_CFE=bistrolink-cfe-staging
S3_BUCKET_IMAGES=bistrolink-images-staging
# ── Almacenamiento R2 (réplica 3-2-1) ─────────────────────────────────────
CF_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET_CFE=bistrolink-cfe-replica
CF_R2_BUCKET_BACKUPS=bistrolink-backups
# ── Observabilidad ─────────────────────────────────────────────────────────
SENTRY_DSN=
LOKI_URL=
LOKI_USERNAME=
LOKI_PASSWORD=
# ── Frontend (NEXT_PUBLIC_ = visible en el navegador) ──────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=bistrolink
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=bistrolink-frontend
NEXT_PUBLIC_MP_PUBLIC_KEY=
NEXT_PUBLIC_SENTRY_DSN=
