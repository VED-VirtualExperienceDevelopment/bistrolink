{
  "name": "bistrolink",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "concurrently@8.2.2 \"npm run start:dev -w apps/backend\" \"npm run dev -w apps/frontend\"",
    "build": "npm run build --workspaces",
    "build:api": "npm run build --workspace=apps/backend",
    "build:web": "npm run build --workspace=apps/frontend",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "test:cov": "npm run test:cov --workspaces",
    "test:pact": "npm run test:pact --workspaces",
    "commit": "bash -i scripts/commit.sh",
    "sync": "bash -i scripts/sync.sh",
    "prepare": "husky",
    "staging:down": "bash -i scripts/staging-down.sh",
    "staging:up": "bash -i scripts/staging-up.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "19.5.0",
    "@commitlint/config-conventional": "19.5.0",
    "concurrently": "8.2.2",
    "husky": "9.1.6"
  },
  "overrides": {
    "picomatch": "4.0.4",
    "multer": "2.2.0",
    "@nestjs/platform-express": {
      "multer": "2.2.0"
    }
  },
  "dependencies": {
    "multer": "^2.2.0"
  }
}
