# BistroLink — Variables de entorno
# Copiar como .env y completar con valores reales.
# El .env está en .gitignore — NUNCA debe commitearse.
# ── Aplicación ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
# ── Base de datos ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bistrolink:bistrolink_dev@localhost:5432/bistrolink_dev
# ── Autenticación ──────────────────────────────────────────────────────────
JWT_SECRET=
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=bistrolink
KEYCLOAK_CLIENT_ID=bistrolink-backend
KEYCLOAK_CLIENT_SECRET=
# ── WhatsApp (Evolution API) ────────────────────────────────────────────────
EVOLUTION_API_URL=http://localhost:8081
EVOLUTION_API_KEY=
# ── Pasarelas de pago ──────────────────────────────────────────────────────
PLEXO_CLIENT_NAME=
PLEXO_CLIENT_PASSWORD=
PLEXO_WEBHOOK_SECRET=
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=
HANDY_API_KEY=
HANDY_WEBHOOK_SECRET=
# ── Facturación electrónica ────────────────────────────────────────────────
SURTEC_API_KEY=
SURTEC_WEBHOOK_SECRET=
# ── Almacenamiento S3 (primario) ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET_CFE=
S3_BUCKET_IMAGES=
# ── Almacenamiento R2 (réplica 3-2-1) ─────────────────────────────────────
CF_R2_ENDPOINT=
CF_ACCOUNT_ID=
CF_R2_ACCESS_KEY_ID=
CF_R2_SECRET_ACCESS_KEY=
CF_R2_BUCKET_CFE=
CF_R2_BUCKET_BACKUPS=
# ── Observabilidad ─────────────────────────────────────────────────────────
SENTRY_DSN=
LOKI_URL=
LOKI_USERNAME=
LOKI_PASSWORD=
# ── Frontend (NEXT_PUBLIC_ = visible en el navegador) ──────────────────────
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=
NEXT_PUBLIC_KEYCLOAK_URL=
NEXT_PUBLIC_KEYCLOAK_REALM=
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=
NEXT_PUBLIC_MP_PUBLIC_KEY=
NEXT_PUBLIC_SENTRY_DSN=
