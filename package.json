{
  "name": "bistrolink",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "concurrently@8.2.2 \"npm run start:dev -w apps/backend\" \"npm run dev -w apps/frontend\"",
    "build": "npm run build --workspaces",
    "build:api": "npm run build --workspace=apps/backend",
    "build:web": "npm run build --workspace=apps/frontend",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "test:cov": "npm run test:cov --workspaces",
    "test:pact": "npm run test:pact --workspaces",
    "commit": "bash scripts/commit.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "8.2.2",
    "husky": "9.1.6",
    "@commitlint/cli": "19.5.0",
    "@commitlint/config-conventional": "19.5.0"
  },
    "overrides": {
    "picomatch": "4.0.4"
  }
}
